# .htaccess for Vue SPA (works at root or in subdirs like /mig/)

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Apache 2.4+: any non-file, non-dir request serves index.html (fixes refresh on /mig/cars, /mig/login, etc.)
  FallbackResource index.html
</IfModule>

# Force correct MIME types for JavaScript modules

<FilesMatch "\.(js|mjs)$">
  ForceType application/javascript
</FilesMatch>
<FilesMatch "\.css$">
ForceType text/css
</FilesMatch>
