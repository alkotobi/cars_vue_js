# /etc/nginx/sites-available/tunnel-merhab
# Generated by tunnel server deploy tooling.
# See deploy/DEPLOYMENT.md for setup instructions.

##
## HTTP → HTTPS redirect
## All cleartext HTTP is redirected to HTTPS, except for ACME HTTP-01
## challenges used by Certbot.
##

server {
    listen      80;
    listen      [::]:80;
    server_name merhab.com *.merhab.com;

    # Allow Let's Encrypt HTTP-01 challenge (used for cert renewal)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

##
## HTTPS: base domain landing (merhab.com, www.merhab.com)
## This serves the tunnel server landing JSON and health checks.
##

server {
    listen      443 ssl;
    listen      [::]:443 ssl;
    server_name merhab.com www.merhab.com;

    ssl_certificate     /etc/letsencrypt/live/merhab.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/merhab.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    # HSTS — tell browsers to always use HTTPS for this host
    add_header Strict-Transport-Security "max-age=63072000" always;

    location / {
        # Tunnel server HTTP listener (plain HTTP on 127.0.0.1:83)
        proxy_pass         http://127.0.0.1:83;

        # Preserve original host and client address
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Reasonable timeouts for landing/health endpoints
        proxy_read_timeout 30s;
    }
}

##
## HTTPS: tunnel subdomains (*.merhab.com)
## Each tunnel client is reachable at <id>.merhab.com and is routed to the
## tunnel server on 127.0.0.1:83. The Go server uses the Host header to
## determine which tunnel to use.
##

server {
    listen      443 ssl;
    listen      [::]:443 ssl;
    server_name ~^(?P<subdomain>[a-z0-9-]+)\.merhab\.com$;

    ssl_certificate     /etc/letsencrypt/live/merhab.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/merhab.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    # HSTS for all tunnel subdomains
    add_header Strict-Transport-Security "max-age=63072000" always;

    ##
    ## WebSocket upgrade support
    ## Required for any WebSocket traffic, even though the current production
    ## model is pure HTTP.
    ##

    proxy_http_version  1.1;
    proxy_set_header    Upgrade    $http_upgrade;
    proxy_set_header    Connection $connection_upgrade;

    ##
    ## Standard proxy headers
    ##

    proxy_set_header    Host              $host;    # e.g. cars.merhab.com
    proxy_set_header    X-Real-IP         $remote_addr;
    proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header    X-Forwarded-Host  $host;
    proxy_set_header    X-Forwarded-Proto $scheme;  # https

    ##
    ## Timeouts and buffering
    ## We disable proxy buffering so responses stream directly from the
    ## tunnel server to the browser. This is important for large downloads
    ## and any future streaming/SSE endpoints.
    ##

    proxy_connect_timeout  10s;
    proxy_send_timeout     300s;
    proxy_read_timeout     300s;
    proxy_buffering        off;
    proxy_cache            off;

    location / {
        # All subdomain traffic goes to the same tunnel server HTTP port.
        proxy_pass http://127.0.0.1:83;
    }
}

##
## WebSocket connection_upgrade map
## This block must live in the http {} context (e.g. in /etc/nginx/nginx.conf
## or a file included from it). It defines $connection_upgrade used above.
##

# http {
#     map $http_upgrade $connection_upgrade {
#         default upgrade;
#         ''      close;
#     }
# }

##
## Certbot / Let's Encrypt (documented in DEPLOYMENT.md)
##
## Example commands:
##
##   apt install certbot
##
##   certbot certonly \
##     --manual \
##     --preferred-challenges dns \
##     -d merhab.com \
##     -d "*.merhab.com"
##
##   # Add the printed TXT record:
##   #   _acme-challenge.merhab.com → <random-token>
##   # Wait for DNS to propagate, then continue.
##
##   # Auto-renewal (in /etc/cron.d/certbot):
##   # 0 3 * * * root certbot renew --quiet && nginx -s reload
##

