# Apache2 configuration for tunnel server (replaces nginx.conf.example).
# See deploy/DEPLOYMENT.md — same architecture: TLS on 443, proxy to 127.0.0.1:83.
#
# Enable required modules:
#   sudo a2enmod ssl rewrite proxy proxy_http proxy_wstunnel headers
#   sudo systemctl reload apache2
#
# Install: copy this to /etc/apache2/sites-available/tunnel-merhab.conf,
# then: sudo a2ensite tunnel-merhab && sudo apache2ctl configtest && sudo systemctl reload apache2

# ---------------------------------------------------------------------------
# HTTP (80): redirect to HTTPS, except ACME challenge for Let's Encrypt
# ---------------------------------------------------------------------------
<VirtualHost *:80>
    ServerName merhab.com
    ServerAlias www.merhab.com
    ServerAlias *.merhab.com

    # Let's Encrypt HTTP-01 challenge
    Alias /.well-known/acme-challenge/ /var/www/certbot/
    <Directory /var/www/certbot>
        Require all granted
    </Directory>

    # Everything else → HTTPS
    RewriteEngine On
    RewriteCond %{REQUEST_URI} !^/.well-known/acme-challenge/
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</VirtualHost>

# ---------------------------------------------------------------------------
# HTTPS (443): base domain (merhab.com, www.merhab.com) → tunnel server :83
# ---------------------------------------------------------------------------
<VirtualHost *:443>
    ServerName merhab.com
    ServerAlias www.merhab.com

    SSLEngine on
    SSLCertificateFile      /etc/letsencrypt/live/merhab.com/fullchain.pem
    SSLCertificateKeyFile   /etc/letsencrypt/live/merhab.com/privkey.pem
    SSLProtocol             all -SSLv3 -TLSv1 -TLSv1.1
    SSLCipherSuite          ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384

    Header always set Strict-Transport-Security "max-age=63072000"

    ProxyPreserveHost On
    ProxyPass / http://127.0.0.1:83/
    ProxyPassReverse / http://127.0.0.1:83/

    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-For "%{REMOTE_ADDR}s"
</VirtualHost>

# ---------------------------------------------------------------------------
# HTTPS (443): tunnel subdomains (*.merhab.com) → tunnel server :83
# Host header (e.g. cars.merhab.com) is preserved so the Go server can route.
# WebSocket upgrade is supported via mod_proxy_wstunnel.
# ---------------------------------------------------------------------------
<VirtualHost *:443>
    ServerName tunnel.merhab.com
    ServerAlias *.merhab.com

    SSLEngine on
    SSLCertificateFile      /etc/letsencrypt/live/merhab.com/fullchain.pem
    SSLCertificateKeyFile   /etc/letsencrypt/live/merhab.com/privkey.pem
    SSLProtocol             all -SSLv3 -TLSv1 -TLSv1.1
    SSLCipherSuite          ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384

    Header always set Strict-Transport-Security "max-age=63072000"

    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-For "%{REMOTE_ADDR}s"

    # WebSocket: upgrade requests to ws:// backend
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} =websocket [NC]
    RewriteRule ^/?(.*) ws://127.0.0.1:83/$1 [P,L]
    RewriteCond %{HTTP:Upgrade} !=websocket [NC]
    RewriteRule ^/?(.*) http://127.0.0.1:83/$1 [P,L]

    # Give tunnel enough time to respond (avoid 504 on slow asset requests)
    ProxyTimeout 120

    ProxyPass / http://127.0.0.1:83/
    ProxyPassReverse / http://127.0.0.1:83/

    # Streaming: avoid buffering so responses stream to the client
    SetEnv proxy-sendchunked 1
    SetEnv proxy-sendcl 0
</VirtualHost>

# ---------------------------------------------------------------------------
# Certbot / Let's Encrypt (same as DEPLOYMENT.md)
#   certbot certonly --manual --preferred-challenges dns -d merhab.com -d "*.merhab.com"
#   Renewal cron: 0 3 * * * root certbot renew --quiet && systemctl reload apache2
# ---------------------------------------------------------------------------
